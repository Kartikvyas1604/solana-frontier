{
  "name": "shieldvault-backend",
  "version": "1.0.0",
  "description": "Non-custodial SOL protection vault backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:deploy": "prisma migrate deploy",
    "worker:price": "tsx src/workers/priceMonitor.worker.ts",
    "worker:trigger": "tsx src/workers/triggerEvaluator.worker.ts",
    "worker:hedge": "tsx src/workers/hedgeManager.worker.ts",
    "worker:fallback": "tsx src/workers/fallback.worker.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@drift-labs/sdk": "^2.92.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.19.0",
    "@pythnetwork/client": "^2.21.0",
    "@solana/web3.js": "^1.95.2",
    "axios": "^1.7.7",
    "bs58": "^5.0.0",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "tweetnacl": "^1.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/bs58": "^4.0.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "prisma": "^5.19.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
