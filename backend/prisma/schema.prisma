generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  walletAddress    String            @id @map("wallet_address")
  createdAt        DateTime          @default(now()) @map("created_at")
  lastSeen         DateTime          @default(now()) @map("last_seen")
  vaultPositions   VaultPosition[]
  protectionRules  ProtectionRule[]
  hedgePositions   HedgePosition[]
  auditLogs        AuditLog[]

  @@map("users")
}

model VaultPosition {
  id            String   @id @default(cuid())
  walletAddress String   @map("wallet_address")
  solAmount     Float    @map("sol_amount")
  shares        Float
  depositedAt   DateTime @default(now()) @map("deposited_at")
  status        String   @default("ACTIVE")
  user          User     @relation(fields: [walletAddress], references: [walletAddress])

  @@index([walletAddress])
  @@map("vault_positions")
}

model ProtectionRule {
  id              String          @id @default(cuid())
  walletAddress   String          @map("wallet_address")
  encryptedRule   String          @map("encrypted_rule")
  ruleHash        String          @map("rule_hash")
  triggerPercent  Float           @map("trigger_percent")
  hedgePercent    Float           @map("hedge_percent")
  timeoutMinutes  Int             @map("timeout_minutes")
  status          String          @default("ACTIVE")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  user            User            @relation(fields: [walletAddress], references: [walletAddress])
  hedgePositions  HedgePosition[]

  @@index([walletAddress, status])
  @@map("protection_rules")
}

model HedgePosition {
  id                String              @id @default(cuid())
  ruleId            String              @map("rule_id")
  walletAddress     String              @map("wallet_address")
  driftPositionId   String?             @map("drift_position_id")
  entryPrice        Float               @map("entry_price")
  shortSizeSol      Float               @map("short_size_sol")
  entryTimestamp    DateTime            @default(now()) @map("entry_timestamp")
  closeTimestamp    DateTime?           @map("close_timestamp")
  closeReason       String?             @map("close_reason")
  fundingPaidTotal  Float               @default(0) @map("funding_paid_total")
  realizedPnl       Float?              @map("realized_pnl")
  status            String              @default("OPEN")
  rule              ProtectionRule      @relation(fields: [ruleId], references: [id])
  user              User                @relation(fields: [walletAddress], references: [walletAddress])
  operatorApprovals OperatorApproval[]
  proofBundles      ProofBundle[]

  @@index([walletAddress, status])
  @@index([ruleId])
  @@map("hedge_positions")
}

model OperatorApproval {
  id                String        @id @default(cuid())
  hedgePositionId   String        @map("hedge_position_id")
  operatorIndex     Int           @map("operator_index")
  signature         String
  approvedAt        DateTime      @default(now()) @map("approved_at")
  priceAtApproval   Float         @map("price_at_approval")
  hedgePosition     HedgePosition @relation(fields: [hedgePositionId], references: [id])

  @@index([hedgePositionId])
  @@map("operator_approvals")
}

model ProofBundle {
  id                  String        @id @default(cuid())
  hedgePositionId     String        @map("hedge_position_id")
  ruleHash            String        @map("rule_hash")
  priceSnapshot       String        @map("price_snapshot") @db.Text
  executionTimestamp  DateTime      @map("execution_timestamp")
  operatorSignatures  String        @map("operator_signatures") @db.Text
  proofData           String        @map("proof_data") @db.Text
  createdAt           DateTime      @default(now()) @map("created_at")
  hedgePosition       HedgePosition @relation(fields: [hedgePositionId], references: [id])

  @@index([hedgePositionId])
  @@map("proof_bundles")
}

model PriceSnapshot {
  id              String   @id @default(cuid())
  pythPrice       Float    @map("pyth_price")
  jupiterPrice    Float    @map("jupiter_price")
  consensusPrice  Float    @map("consensus_price")
  deviationPercent Float   @map("deviation_percent")
  isValid         Boolean  @map("is_valid")
  capturedAt      DateTime @default(now()) @map("captured_at")

  @@index([capturedAt])
  @@map("price_snapshots")
}

model AuditLog {
  id            String   @id @default(cuid())
  walletAddress String?  @map("wallet_address")
  action        String
  metadata      String   @db.Text
  timestamp     DateTime @default(now())
  user          User?    @relation(fields: [walletAddress], references: [walletAddress])

  @@index([walletAddress, timestamp])
  @@map("audit_logs")
}
