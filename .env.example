# Cipher Yield - Production Environment

# Solana Configuration
SOLANA_RPC_URL=http://127.0.0.1:8899
SOLANA_WS_URL=ws://127.0.0.1:8900
PROGRAM_ID=CipherVau1t11111111111111111111111111111111

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cipher_vault?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Operator Configuration
OPERATOR_INDEX=1

# Thresholds
PRICE_STALENESS_THRESHOLD_MS=3000
MAX_SLIPPAGE_BPS=50
CIRCUIT_BREAKER_THRESHOLD=0.15

# Environment
NODE_ENV=development
