{
  "name": "solana-frontier",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "programs/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "program:build": "cd programs/cipher-yield && NO_DNA=1 anchor build",
    "program:test": "cd programs/cipher-yield && NO_DNA=1 anchor test",
    "program:deploy": "cd programs/cipher-yield && NO_DNA=1 anchor deploy"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5",
    "prettier": "^3.2.5"
  }
}
